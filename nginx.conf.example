# ================================================================
# Nginx Config — AMI System Production
# ================================================================
# Cara pakai:
#   sudo cp nginx.conf.example /etc/nginx/sites-available/ami
#   sudo ln -s /etc/nginx/sites-available/ami /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl restart nginx
#
# Ganti "ami.yourdomain.com" dengan domain Anda yang sebenarnya
# Ganti "/var/www/ami" dengan path deploy Anda
# ================================================================

# Redirect HTTP → HTTPS (aktifkan setelah SSL terpasang)
# server {
#     listen 80;
#     server_name ami.yourdomain.com;
#     return 301 https://$host$request_uri;
# }

server {
    listen 80;
    # listen 443 ssl;                          # Aktifkan untuk HTTPS
    server_name ami.yourdomain.com;

    # ── SSL (Let's Encrypt / Certbot) ──────────────────────────
    # ssl_certificate     /etc/letsencrypt/live/ami.yourdomain.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/ami.yourdomain.com/privkey.pem;
    # include             /etc/letsencrypt/options-ssl-nginx.conf;
    # ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # ── Keamanan dasar ─────────────────────────────────────────
    add_header X-Frame-Options       "SAMEORIGIN"   always;
    add_header X-Content-Type-Options "nosniff"      always;
    add_header X-XSS-Protection      "1; mode=block" always;
    add_header Referrer-Policy       "strict-origin-when-cross-origin" always;

    # ── Gzip compression ───────────────────────────────────────
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types
        text/plain text/css text/xml text/javascript
        application/javascript application/json application/xml
        application/rss+xml image/svg+xml;

    # ── Upload size (max PDF 10MB + overhead) ──────────────────
    client_max_body_size 15M;

    # ── Frontend: serve static files dari Vite build ───────────
    root /var/www/ami/client/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;   # SPA fallback

        # Cache HTML singkat (agar update langsung terasa)
        location ~* \.html$ {
            expires 1m;
            add_header Cache-Control "public, no-cache";
        }
    }

    # Cache aset statis Vite (JS/CSS/gambar) — hash di nama file
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # ── API: proxy ke Express backend ──────────────────────────
    location /api/ {
        proxy_pass         http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade          $http_upgrade;
        proxy_set_header   Connection       "upgrade";
        proxy_set_header   Host             $host;
        proxy_set_header   X-Real-IP        $remote_addr;
        proxy_set_header   X-Forwarded-For  $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 60s;
    }

    # ── Upload files: proxy ke Express ─────────────────────────
    location /uploads/ {
        proxy_pass         http://127.0.0.1:3001;
        proxy_set_header   Host             $host;
        proxy_set_header   X-Real-IP        $remote_addr;
        expires 30d;
        add_header Cache-Control "public";
    }

    # ── Log ────────────────────────────────────────────────────
    access_log /var/log/nginx/ami-access.log;
    error_log  /var/log/nginx/ami-error.log;
}
