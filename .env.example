# ================================================================
# KONFIGURASI SERVER AMI SYSTEM
# Salin file ini ke .env dan sesuaikan nilainya
# ================================================================

# Port server backend
PORT=3001

# Secret key JWT — WAJIB diganti dengan string random yang panjang!
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ganti-dengan-secret-random-panjang-minimal-32-karakter

# Lokasi file database SQLite
DB_PATH=./data/ami.db

# Folder upload PDF
UPLOAD_DIR=./uploads

# Origin frontend (untuk CORS)
CORS_ORIGIN=http://localhost:5173

# Mode lingkungan: development | production
NODE_ENV=development
